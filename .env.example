# ---- Root environment for Docker Compose ----
# Copy this file to ".env" before running `docker compose up`.
# Never commit the real .env file (it is gitignored).

POSTGRES_USER=inventory
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=inventory

# CORS for the backend. In local compose the frontend talks to the backend
# through the nginx /api proxy (same origin), so "*" is fine here.
CORS_ORIGINS=*

LOW_STOCK_THRESHOLD=10
SEED_ON_STARTUP=true

# Auth — change SECRET_KEY to a strong random value in production.
SECRET_KEY=dev-secret-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
