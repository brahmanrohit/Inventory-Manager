# ---- Backend environment variables ----
# For local Docker Compose, the individual POSTGRES_* values are used.
# For cloud hosting (Render/Railway), set DATABASE_URL instead.

# DATABASE_URL=postgresql://user:password@host:5432/dbname

POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory
POSTGRES_DB=inventory
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CORS: comma-separated list of allowed frontend origins, or * for all.
# In production set this to your deployed frontend URL, e.g.:
# CORS_ORIGINS=https://your-frontend.vercel.app
CORS_ORIGINS=*

LOW_STOCK_THRESHOLD=10
SEED_ON_STARTUP=true

# Auth — MUST set a strong random SECRET_KEY in production (signs JWT tokens).
SECRET_KEY=dev-secret-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
