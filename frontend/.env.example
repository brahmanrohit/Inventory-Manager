# Base URL of the backend API.
# - Local dev (vite): leave as /api to use the dev proxy.
# - Docker Compose: set to http://localhost:8000 (built into the image).
# - Production (Vercel/Netlify): set to your live backend URL, e.g.
#   VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=/api
